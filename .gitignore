# .gitignore - MC Server Framework

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虛擬環境
venv/
env/
ENV/

# 建置檔案
build/
dist/
*.egg-info/

# PyInstaller
*.manifest
*.exe  # 忽略編譯的執行檔

# 保留 PyInstaller spec 配置（需要版本控制）
!mc-server-framework.spec

# 發佈檔案
release/
*.zip

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 伺服器實例（保留結構但忽略內容）
servers/*/server/*
servers/*/runtime/*
servers/*/backups/*
servers/*/temp/*
!servers/*/.gitkeep
!servers/*/server.yml

# 排除 .gitkeep
!.gitkeep

# 日誌
logs/
*.log

# 暫存檔案
*.tmp
*.bak

# 設定檔（可能包含敏感資訊）
config/app.yml
config/java_registry.yml

# 保留範本
!templates/

# OS
.DS_Store
Thumbs.db

# Servers
servers/*